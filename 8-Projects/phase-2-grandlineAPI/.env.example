# ─── Grand Line API — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file — add it to .gitignore.

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite file path relative to the project root
# Change this to postgresql://user:pass@host/db when you move to Postgres later
DATABASE_URL=sqlite:///./grandline.db

# ─── JWT Authentication ───────────────────────────────────────────────────────
# A long random string used to sign JWT tokens — treat it like a password
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-string

# Signing algorithm — HS256 is standard for symmetric JWTs
ALGORITHM=HS256

# How long a token stays valid (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Marine Credentials (seed user for testing) ───────────────────────────────
# This is the hardcoded marine/admin login used before a real user DB is added
MARINE_USERNAME=sengoku
MARINE_PASSWORD=marineford
